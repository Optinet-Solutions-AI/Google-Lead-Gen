{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/scheduler/tick",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/monday/sync?board=leads",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/monday/sync?board=affiliates",
      "schedule": "10 23 * * *"
    },
    {
      "path": "/api/monday/sync?board=not_relevant_leads",
      "schedule": "20 23 * * *"
    },
    {
      "path": "/api/monday/sync?board=email_undelivered_leads",
      "schedule": "30 23 * * *"
    },
    {
      "path": "/api/proxy/bandwidth/refresh",
      "schedule": "*/5 * * * *"
    }
  ]
}
