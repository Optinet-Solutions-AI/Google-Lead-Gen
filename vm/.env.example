# ============================================================
# VM Scrape Worker — Environment Variables
# Copy to /home/ubuntu/.env on the VM. NEVER commit.
# ============================================================

# Unique worker id (for logs + claimed_by). Include the vm name so
# we can tell which VM ran which job.
WORKER_ID=vm1-9222

# Chrome debugger port — MUST be unique per concurrent worker on
# the same VM. 9222 / 9223 / 9224 is a sensible starting set.
GOLOGIN_PORT=9222

# How often (seconds) to ask Supabase for a new job when idle.
POLL_INTERVAL_SECONDS=5

# Max time a single scrape can run before we kill it. 20 min is
# generous — most 5-page scrapes finish in 2-4 min.
SCRAPE_TIMEOUT_SECONDS=1200

# Where the scraper lives on disk. Defaults to ~/scraper.py
# SCRAPER_PATH=/home/ubuntu/scraper.py
# KILL_SCRIPT_PATH=/home/ubuntu/kill_gologin.py

# Per-worker output path prefix. Each scrape writes to
# $RESULTS_DIR/scrape_${WORKER_ID}_${GOLOGIN_PORT}.json so concurrent
# workers don't stomp on each other.
RESULTS_DIR=/tmp

# ------------------------------------------------------------
# Supabase (same as the Next.js app)
# ------------------------------------------------------------
SUPABASE_URL=https://veqfloktkejmyueskltp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ------------------------------------------------------------
# GoLogin API — read by the scraper (moved out of the Python source)
# ------------------------------------------------------------
GOLOGIN_API_TOKEN=eyJhbGci...

# ------------------------------------------------------------
# Kick.com API — read by kick_search.py (search_engine='kick' jobs)
# ------------------------------------------------------------
# OAuth 2.1 Client Credentials. Tokens last 60 days; the script
# fetches a fresh one each run for Phase 1 simplicity. Source:
# kick.com → Profile → Settings → Developer → Create an App.
KICK_CLIENT_ID=01HXXXXXXXXXXXXXXXXXXXXXXX
KICK_CLIENT_SECRET=<your-kick-client-secret>

# ------------------------------------------------------------
# Kick Phase 2 — profile enrichment (operator-triggered ▶)
# ------------------------------------------------------------
# Unlike Phase 1 (pure HTTP), Phase 2 drives a real GoLogin/Chromium
# session over kick.com/{slug} to backfill socials, follower count, and
# promo/pinned-chat links into kick_streamers/kick_links. It reuses
# scraper.py's Cloudflare/2Captcha plumbing, so the same GOLOGIN_*,
# CAPTCHA_SOLVER_MODE, TWOCAPTCHA_API_KEY, and DISPLAY vars apply.
#
# Max streamers enriched per ▶ run, ranked by live viewers / subscribers.
# Caps Cloudflare exposure + runtime (each is a slow page load).
KICK_PHASE2_TOP_N=25
# Where the Phase-2 script lives on disk. Defaults to ~/kick_profile_scrape.py
# KICK_PROFILE_SCRAPE_PATH=/home/ubuntu/kick_profile_scrape.py
#
# Failure mitigation (Kick's WAF blocks scraper IPs under load). Each
# streamer uses a fresh GoLogin session/IP; these tune reliability vs speed:
#   KICK_PHASE2_MAX_TRIES            fresh-IP attempts per streamer (default 4)
#   KICK_PHASE2_STREAMER_DELAY_SECONDS  pause between streamers (default 5)
#   KICK_PHASE2_BLOCK_COOLDOWN_SECONDS  pause before a retry IP (default 12)
# KICK_PHASE2_MAX_TRIES=3
# KICK_PHASE2_STREAMER_DELAY_SECONDS=5
# KICK_PHASE2_BLOCK_COOLDOWN_SECONDS=12
# Wall-clock budget per run: stop starting new streamers past this and exit
# cleanly (rest stay pending for a re-run), so the job never hits the
# worker's subprocess timeout and requeues. Keep under 1200s.
# KICK_PHASE2_BUDGET_SECONDS=1000

# X server used by GoLogin's Chromium (headful behind VNC).
# Must match whatever runs xvfb / x11vnc.
DISPLAY=:1
