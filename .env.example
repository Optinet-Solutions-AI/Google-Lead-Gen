# ============================================================
# Google Lead Gen — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Next.js
# ------------------------------------------------------------
# The canonical URL of your deployment (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Server-only: service role key — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Used by Supabase CLI (migrations, type generation)
SUPABASE_PROJECT_ID=<your-project-id>

# ------------------------------------------------------------
# Authentication (if using Supabase Auth)
# ------------------------------------------------------------
# Redirect URL after OAuth sign-in
NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# ------------------------------------------------------------
# Google APIs (for lead-gen integrations)
# ------------------------------------------------------------
# OAuth 2.0 credentials — Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=<your-developer-token>
GOOGLE_ADS_CUSTOMER_ID=<your-customer-id>

# ------------------------------------------------------------
# Database (direct connection — for migrations / scripts)
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/<db>

# ------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------
# Set to "development" | "staging" | "production"
NODE_ENV=development
