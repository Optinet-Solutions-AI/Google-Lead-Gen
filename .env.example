# ============================================================
# Google Lead Gen — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Next.js
# ------------------------------------------------------------
# The canonical URL of your deployment (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Server-only: service role key — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Used by Supabase CLI (migrations, type generation)
SUPABASE_PROJECT_ID=<your-project-id>

# ------------------------------------------------------------
# Authentication (if using Supabase Auth)
# ------------------------------------------------------------
# Redirect URL after OAuth sign-in
NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# ------------------------------------------------------------
# Google APIs (for lead-gen integrations)
# ------------------------------------------------------------
# OAuth 2.0 credentials — Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=<your-developer-token>
GOOGLE_ADS_CUSTOMER_ID=<your-customer-id>

# MyMemory translation API — used to translate non-English scrape
# keywords to English on the scrape detail page so QA can read what
# they're reviewing. No API key needed; the free tier is 5k words/day
# per IP anonymously. Set this email and the daily quota goes up to
# 50k words/day (MyMemory doesn't verify the address — it's just a
# label so they know who's hitting them). Optional — when unset, the
# anonymous quota applies.
MYMEMORY_EMAIL=<your-team-email>

# ------------------------------------------------------------
# Kick.com API (streaming-platform scraping target)
# ------------------------------------------------------------
# OAuth 2.1 credentials — Kick Profile → Developer → Create an App.
# We only use the App Access Token (Client Credentials) flow, which
# accesses publicly available channel/category data. No user OAuth
# dance, no redirect callback. Token endpoint: https://id.kick.com
# Data endpoint: https://api.kick.com/public/v1
KICK_CLIENT_ID=<your-kick-client-id>
KICK_CLIENT_SECRET=<your-kick-client-secret>

# ------------------------------------------------------------
# Monday.com API (for Monday board replica sync)
# ------------------------------------------------------------
# API base URL — use v2
MONDAY_API_URL=https://api.monday.com/v2

# OAuth / app credentials — Monday Dashboard → Developers → Your App
MONDAY_CLIENT_ID=<your-client-id>
MONDAY_CLIENT_SECRET=<your-client-secret>
MONDAY_SIGNING_SECRET=<your-signing-secret>
MONDAY_APP_ID=<your-app-id>
MONDAY_APP_SLUG=<your-app-slug>

# Personal API token — create at Profile → Developers → My Access Tokens
# Used by scripts/monday/*.ts for server-side data export
MONDAY_API_TOKEN=<your-personal-api-token>

# ------------------------------------------------------------
# GoLogin API (scraping browser profiles)
# ------------------------------------------------------------
# Token from GoLogin dashboard — Settings → API
# Used by scripts/gologin/sync-profiles.ts and by the VM worker
GOLOGIN_API_URL=https://api.gologin.com
GOLOGIN_API_TOKEN=<your-gologin-api-token>

# ------------------------------------------------------------
# Enigma proxy bandwidth tracking
# ------------------------------------------------------------
# The metered residential proxy our scrapes run through (resi.enigmaproxy.net).
# The bandwidth poller (/api/proxy/bandwidth/refresh) reads remaining GB from
# Enigma's Customer API. Mint a key in the Enigma dashboard → Customer API
# panel → "Generate key" (format `epk_…`). It's a bearer key with no expiry
# and no IP binding, so it works from Vercel. Revoke/regenerate there if leaked.
ENIGMA_API_KEY=<epk_…-key-from-enigma-dashboard-Customer-API>

# ------------------------------------------------------------
# Enigma proxy — STICKY exit for Google-login profiles
# ------------------------------------------------------------
# Used only by scripts/gologin/set-sticky-proxy.ts, which rewrites the proxy
# stored on each Google-login GoLogin profile from a rotating exit to a stable IP
# per country (Google logs accounts out when the egress IP rotates). NOT read at
# scrape time — gl.start() uses whatever proxy is stored on the profile.
# The script reads each profile's current `<secret>_country-XX` password and
# APPENDS this token to pin the IP. {country} → ISO-2, uppercased per profile.
# Confirm the exact sticky syntax (token name, length, optional _lifetime-) in
# your Enigma dashboard. Keep the session value STABLE per country.
ENIGMA_STICKY_SUFFIX_TEMPLATE=_session-sticky{country}

# ------------------------------------------------------------
# Database (direct connection — for migrations / scripts)
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/<db>

# ------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------
# Set to "development" | "staging" | "production"
NODE_ENV=development

# ------------------------------------------------------------
# Human-in-the-loop noVNC (interactive checkpoints)
# ------------------------------------------------------------
# Public base URL of the VM's noVNC endpoint (TLS, no trailing slash).
# Example: https://vnc.lead-gen.example.com
# When unset, /admin/interactive shows checkpoints but disables the
# "Open VNC" button (operators would need a TightVNC client to act).
NEXT_PUBLIC_VNC_BASE_URL=

# Shared HMAC secret used to sign noVNC URLs. Must match the
# corresponding nginx Lua config on the VM (see docs/runbook-novnc.md).
# Generate with: openssl rand -hex 32
INTERACTIVE_VNC_HMAC_SECRET=
